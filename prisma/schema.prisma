// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model LastfmCache {
  key       String   @id
  value     Json?
  expiresAt DateTime @map("expires_at")

  @@map("lastfm_cache")
}
